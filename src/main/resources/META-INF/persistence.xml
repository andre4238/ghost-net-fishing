<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="ghostnetfishingPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Datenbank-Verbindung ueber den in Payara konfigurierten
             JDBC-Pool (Resource jdbc/ghostnet -> MySQL ghostnetfishing).
             Bei RESOURCE_LOCAL ist das die non-jta-data-source. -->
        <non-jta-data-source>jdbc/ghostnet</non-jta-data-source>

        <!-- Entities explizit gelistet -->
        <class>de.iu.ghostnetfishing.model.Person</class>
        <class>de.iu.ghostnetfishing.model.Geisternetz</class>

        <properties>
            <!-- Hibernate-Einstellungen -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

            <!-- Load-Time-Bytecode-Enhancement abschalten.
                 Sonst registriert Payara Hibernates Klassen-Transformer, der beim
                 Deployen einen ClassCircularityError ausloest (Payara-Bug FISH-7338).
                 Fuer diese App wird die Enhancement nicht benoetigt. -->
            <property name="hibernate.enhancer.enableDirtyTracking" value="false"/>
            <property name="hibernate.enhancer.enableLazyInitialization" value="false"/>
            <property name="hibernate.enhancer.enableAssociationManagement" value="false"/>
        </properties>

    </persistence-unit>
</persistence>
